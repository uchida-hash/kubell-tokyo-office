# ============================================================
# Belle Office - 環境変数サンプル
# このファイルをコピーして .env.local を作成し、値を設定してください
# ============================================================

# ── Next Auth ──────────────────────────────────────────────
NEXTAUTH_URL=https://your-app.vercel.app
NEXTAUTH_SECRET=your-nextauth-secret-32chars-or-more  # openssl rand -base64 32

# ── Google OAuth ───────────────────────────────────────────
# GCP Console > APIs & Services > Credentials > OAuth 2.0 Client IDs
GOOGLE_CLIENT_ID=xxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxx

# 許可するメールドメイン（会社ドメイン）
ALLOWED_EMAIL_DOMAIN=yourcompany.com
NEXT_PUBLIC_ALLOWED_DOMAIN=yourcompany.com

# ── Firebase (クライアント) ────────────────────────────────
# Firebase Console > プロジェクト設定 > マイアプリ > ウェブアプリ
NEXT_PUBLIC_FIREBASE_API_KEY=AIzaSy...
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789
NEXT_PUBLIC_FIREBASE_APP_ID=1:123456789:web:abcdef

# ── Firebase Admin SDK (サーバーサイド) ───────────────────
# Firebase Console > プロジェクト設定 > サービスアカウント > 新しい秘密鍵を生成
FIREBASE_ADMIN_PROJECT_ID=your-project-id
FIREBASE_ADMIN_CLIENT_EMAIL=firebase-adminsdk-xxxx@your-project.iam.gserviceaccount.com
FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEvQ...\n-----END PRIVATE KEY-----\n"

# ── Google Calendar ────────────────────────────────────────
# 共有カレンダーID（Google カレンダーの設定 > カレンダーの統合 > カレンダーID）
GOOGLE_CALENDAR_ID=your-company-calendar@group.calendar.google.com

# サービスアカウントで取得する場合（推奨）
# GCP Console > IAM > サービスアカウント で作成し、カレンダーに共有設定
GOOGLE_CALENDAR_SERVICE_ACCOUNT_EMAIL=calendar-reader@your-project.iam.gserviceaccount.com
GOOGLE_CALENDAR_SERVICE_ACCOUNT_KEY="-----BEGIN PRIVATE KEY-----\n..."

# ── Chatwork Webhook ───────────────────────────────────────
# Chatwork 管理者画面 > Webhook > トークン
CHATWORK_WEBHOOK_TOKEN=your-chatwork-webhook-token
